# ─── AWS S3 ───────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# ─── Server ───────────────────────────────────────────────
PORT=3001
CLIENT_URL=http://localhost:5173

# ─── Paths ────────────────────────────────────────────────
# Ruta absoluta a tu banco de imágenes local
IMAGES_PATH=./data/images
# Carpeta donde se guardan los videos generados
OUTPUT_PATH=./output
# Carpeta donde se guardan las imágenes estáticas generadas
OUTPUT_IMAGES_PATH=./output-images
# Ruta a la carpeta de fuentes personalizadas
FONTS_PATH=./data/fonts

# ─── n8n Webhooks ─────────────────────────────────────────
WEBHOOK_TEST_URL=https://n8n.example.com/webhook-test/videopublish
WEBHOOK_PROD_URL=https://n8n.example.com/webhook/videopublish
WEBHOOK_S3_URL=https://n8n.example.com/webhook/organic-intelligence

# ─── App ──────────────────────────────────────────────────
# URL pública de esta app (para generar links directos a videos locales)
PUBLIC_BASE_URL=http://localhost:3001

# ─── Google Gemini (generación de frases y metadatos) ─────
GEMINI_API_KEY=

# ─── Unsplash (búsqueda de imágenes) ─────────────────────
UNSPLASH_ACCESS_KEY=

# ─── gallery-dl (importación desde Pinterest) ─────────────
# Ruta al ejecutable. Vacío = busca en PATH global
GALLERY_DL_PATH=gallery-dl

# ─── Google Drive (OAuth2) ────────────────────────────────
GOOGLE_OAUTH_CREDENTIALS_PATH=./credentials/google-service-account.json
GOOGLE_OAUTH_TOKEN_PATH=./credentials/drive-token.json
GOOGLE_DRIVE_FOLDER_ID=
